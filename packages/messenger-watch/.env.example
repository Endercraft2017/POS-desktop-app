# messenger-watch configuration. Copy to .env and fill in real values.
# On the Kali server this file lives at /var/www/3ks.afkcube.com/messenger-watch/.env

# Where to POST detected messages. Use 127.0.0.1 from the server itself.
INGEST_URL=http://127.0.0.1:3001/api/messenger/scrape-ingest
INGEST_TOKEN=replace-with-shared-secret

# Browser
CHROMIUM_EXECUTABLE=/usr/bin/chromium
AUTH_STATE_PATH=/var/www/3ks.afkcube.com/messenger-watch/auth-state.json
HEADLESS=true
START_URL=https://business.facebook.com/latest/inbox/

# How often to checkpoint cookies back to auth-state.json (minutes)
STATE_SAVE_INTERVAL_MIN=15

# Rate caps (see README)
MAX_EVENTS_PER_HOUR=30
MAX_EVENTS_PER_SESSION=500
RESTART_AFTER_HOURS=6

# Logging
LOG_LEVEL=info
